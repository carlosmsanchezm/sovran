# Terraform specific files
*.tfstate
*.tfstate.*
*.tfplan
*.tfplan.*
.terraform/
.terraform.lock.hcl

# Variable files with sensitive data
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, except for .tfvars.example
*.tfvars
!*.tfvars.example

# Include override files you do wish to add to version control
# override.tf
# override.tf.json

# Include tfplan files you do wish to add to version control
# *.tfplan

# Ignore CLI configuration files
.terraformrc
terraform.rc

# OS specific files
.DS_Store
Thumbs.db

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak

# Helm values generated from Terraform
helm_values.json
aegis-services-values.yaml
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
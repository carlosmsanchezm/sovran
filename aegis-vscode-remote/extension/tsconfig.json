{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "types": ["node", "jest"]
  },
  "exclude": [
    "__tests__/e2e",
    "__tests__/e2e-real",
    "test-results",
    "scripts",
    "__mocks__"
  ]
}

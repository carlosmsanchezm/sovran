{
  "name": "aegis-remote",
  "displayName": "Aegis Remote (MVP)",
  "publisher": "aegis",
  "version": "0.0.1",
  "extensionKind": [
    "ui"
  ],
  "engines": {
    "vscode": "^1.99.0"
  },
  "enabledApiProposals": [
    "resolvers",
    "tunnels"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:aegis.connect",
    "onCommand:aegis.disconnect",
    "onCommand:aegis.showLogs",
    "onCommand:aegis.reconnect",
    "onCommand:aegis.showDiagnostics",
    "onView:aegis.workspaces",
    "onResolveRemoteAuthority:aegis",
    "onAuthenticationRequest:aegis"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "test:unit": "jest -c jest.config.js --runInBand",
    "test:integration": "jest -c jest.config.js --runInBand --coverage=false --testPathPattern=__tests__/integration",
    "test:e2e": "node ./scripts/build-e2e-runner.js && node ./__tests__/e2e/run-vscode-tests.js",
    "build:test-e2e": "tsc -p tsconfig.e2e.json",
    "build:test-e2e:real": "tsc -p __tests__/e2e-real/tsconfig.json",
    "test:e2e:real": "npm run build && npm run build:test-e2e:real && ts-node ./scripts/prepare-real-workspace.ts && node ./__tests__/e2e/run-vscode-tests-real.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "aegis.connect",
        "title": "Aegis: Connect"
      },
      {
        "command": "aegis.disconnect",
        "title": "Aegis: Disconnect"
      },
      {
        "command": "aegis.showLogs",
        "title": "Aegis: Show Logs"
      },
      {
        "command": "aegis.reconnect",
        "title": "Aegis: Reconnect"
      },
      {
        "command": "aegis.showDiagnostics",
        "title": "Aegis: Show Diagnostics"
      },
      {
        "command": "aegis.refreshWorkspaces",
        "title": "Aegis: Refresh Workspaces"
      },
      {
        "command": "aegis.signIn",
        "title": "Aegis: Sign In"
      },
      {
        "command": "aegis.signOut",
        "title": "Aegis: Sign Out"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "aegis.workspaces",
          "name": "Aegis Workspaces"
        }
      ]
    },
    "authentication": [
      {
        "label": "Aegis Platform",
        "id": "aegis",
        "supportsMultipleAccounts": false
      }
    ],
    "configuration": {
      "title": "Aegis Remote",
      "properties": {
        "aegisRemote.platform.url": {
          "type": "string",
          "default": "",
          "description": "Platform URL for auto-discovery (e.g. aegis.company.mil). When set, all other platform/auth settings are derived automatically. This is the only setting most users need."
        },
        "aegisRemote.platform.grpcEndpoint": {
          "type": "string",
          "default": "",
          "description": "Host:port for the Aegis Platform gRPC endpoint. Leave empty if platform.url is set (auto-discovered)."
        },
        "aegisRemote.platform.grpcServerName": {
          "type": "string",
          "default": "",
          "description": "TLS server name override for gRPC connections. Set when the endpoint hostname differs from the server certificate SAN (e.g. localhost connecting to a TLS server with cert for platform-api-grpc.localtest.me)."
        },
        "aegisRemote.platform.namespace": {
          "type": "string",
          "default": "default",
          "description": "Logical namespace or environment hint passed to Platform APIs (optional)."
        },
        "aegisRemote.platform.authScope": {
          "type": "string",
          "default": "aegis-platform",
          "description": "Authentication scope/audience requested for Platform access tokens."
        },
        "aegisRemote.platform.projectId": {
          "type": "string",
          "default": "",
          "description": "Project identifier whose interactive workspaces should be listed."
        },
        "aegisRemote.auth.authority": {
          "type": "string",
          "default": "",
          "description": "OIDC issuer / realm base URL (e.g. https://keycloak.localtest.me/realms/aegis)."
        },
        "aegisRemote.auth.clientId": {
          "type": "string",
          "default": "",
          "description": "Public OAuth client identifier registered for the VS Code extension."
        },
        "aegisRemote.auth.redirectUri": {
          "type": "string",
          "default": "vscode://aegis.aegis-remote/auth",
          "description": "Redirect URI configured for the Keycloak client (must match exactly)."
        },
        "aegisRemote.auth.scopes": {
          "type": "array",
          "default": [
            "openid",
            "profile",
            "email",
            "offline_access"
          ],
          "items": {
            "type": "string"
          },
          "description": "Additional OAuth scopes requested during sign-in."
        },
        "aegisRemote.auth.prompt": {
          "type": "string",
          "default": "",
          "description": "Optional prompt parameter sent during authorization requests (e.g. \"login\" or \"consent\")."
        },
        "aegisRemote.defaultWorkspaceId": {
          "type": "string",
          "default": "",
          "description": "Fallback workspace identifier when none is provided (optional)."
        },
        "aegisRemote.heartbeatIntervalMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "Interval in milliseconds for WebSocket keepalive pings."
        },
        "aegisRemote.idleTimeoutMs": {
          "type": "number",
          "default": 45000,
          "minimum": 1000,
          "description": "Terminate connections that have been idle (no inbound bytes) for this long."
        },
        "aegisRemote.security.rejectUnauthorized": {
          "type": "boolean",
          "default": true,
          "description": "Reject servers whose certificates cannot be validated against the provided CA bundle."
        },
        "aegisRemote.security.mtlsSource": {
          "type": "string",
          "default": "platform",
          "enum": [
            "platform",
            "system"
          ],
          "description": "Where to source client mTLS material: from Platform-issued tickets or local system store."
        },
        "aegisRemote.security.caPath": {
          "type": "string",
          "default": "",
          "description": "Path to an additional CA bundle to trust when connecting to the proxy (optional)."
        },
        "aegisRemote.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "info",
            "debug",
            "trace"
          ],
          "description": "Verbosity of client logs emitted to the output channel."
        }
      }
    }
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.6",
    "@grpc/proto-loader": "^0.7.13",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "@types/rewire": "^2.5.28",
    "@types/vscode": "^1.99.0",
    "@types/ws": "^8.5.10",
    "@vscode/dts": "^0.4.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "execa": "^9.3.0",
    "get-port": "^7.1.0",
    "http-proxy": "^1.18.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mocha": "^10.7.3",
    "mocha-junit-reporter": "^2.2.0",
    "otplib": "^12.0.1",
    "playwright": "^1.56.1",
    "portfinder": "^1.0.32",
    "rewire": "^6.0.0",
    "rimraf": "^6.0.1",
    "tmp": "^0.2.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "minimatch": "^10.2.3",
    "jws": "^4.0.0",
    "glob": "^11.1.0",
    "test-exclude": "^7.0.1"
  }
}

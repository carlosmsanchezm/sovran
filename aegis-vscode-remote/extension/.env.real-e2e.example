# Copy this file to .env.real-e2e and fill in real values before running
# scripts/run-real-e2e.sh. Keep secrets like AEGIS_TEST_TOKEN out of version control.

AEGIS_GRPC_ADDR=platform-api-grpc.localtest.me:443
AEGIS_TEST_EMAIL=dev-user@example.com
AEGIS_TEST_TOKEN=replace-with-real-token
AEGIS_PROJECT_ID=p-vscode-e2e
AEGIS_PLATFORM_NAMESPACE=aegis-system
AEGIS_CA_PEM=/Users/youruser/aegis-platform-api-ca.crt
AEGIS_TEST_QUEUE=default
AEGIS_TEST_FLAVOR=cpu-small
AEGIS_TEST_IMAGE=carlosmsanchez/aegis-workspace-vscode:latest
AEGIS_TEST_CLUSTER_ID=dev-local
AEGIS_WORKSPACE_READY_TIMEOUT_MS=240000
AEGIS_E2E_DEBUG=1
NODE_EXTRA_CA_CERTS=/Users/youruser/aegis-platform-api-ca.crt

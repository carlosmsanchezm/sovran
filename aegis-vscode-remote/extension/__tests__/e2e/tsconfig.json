{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "../../out-e2e/suite",
    "rootDir": "./suite",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": "../src",
    "paths": {
      "./platform": ["../src/__tests__/stubs/platform.e2e.stub"],
      "./ui": ["../src/__tests__/stubs/ui.e2e.stub"],
      "./config": ["../src/__tests__/stubs/config.e2e.stub"],
      "./diagnostics": ["../src/__tests__/stubs/diagnostics.stub"]
    }
  },
  "include": ["suite/**/*"]
}
